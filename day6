<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Day 6 — Train Execution Under Pressure</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1018;
  --cream: #faf6f0;
  --accent: #c9462e;
  --accent2: #e8a030;
  --muted: #7a6e6a;
  --safe: #4a8c5c;
  --border: rgba(26,16,24,0.08);
  --load-low: #4a8c5c;
  --load-mid: #e8a030;
  --load-high: #c9462e;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--ink);font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.7;overflow-x:hidden;}
.slide{min-height:100vh;width:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:80px 40px 80px;position:relative;overflow:hidden;opacity:0;transform:translateY(24px);transition:opacity 0.8s ease,transform 0.8s ease;}
.slide.active{opacity:1;transform:translateY(0);}
header{position:fixed;top:0;left:0;right:0;height:56px;background:rgba(250,246,240,0.96);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 32px;z-index:200;}
.logo{font-family:'Playfair Display',serif;font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);}
.day-badge{background:var(--ink);color:var(--cream);font-size:11px;font-weight:600;letter-spacing:.1em;padding:5px 14px;text-transform:uppercase;}
.nav-pills{display:flex;gap:6px;align-items:center;}
.pill{width:28px;height:5px;border-radius:3px;background:#d0c8c0;cursor:pointer;transition:all 0.3s;}
.pill.active{background:var(--accent);width:40px;}
.pill.done{background:var(--accent2);}
#prog{position:fixed;top:56px;left:0;height:2px;background:var(--accent);z-index:201;transition:width 0.4s ease;}
.nav-arrow{position:fixed;bottom:32px;background:var(--ink);color:var(--cream);border:none;cursor:pointer;width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:18px;z-index:200;transition:all 0.2s;}
.nav-arrow:hover{background:var(--accent);}
#nav-prev{left:40px;}#nav-next{right:40px;}
.slide-counter{position:fixed;bottom:38px;left:50%;transform:translateX(-50%);font-size:12px;font-weight:600;color:var(--muted);z-index:200;letter-spacing:.1em;}
.label{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
h1{font-family:'Playfair Display',serif;font-size:clamp(40px,7vw,80px);font-weight:900;line-height:1.05;margin-bottom:24px;}
h2{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);font-weight:700;line-height:1.15;margin-bottom:20px;}
.lead{font-size:18px;line-height:1.65;color:#3d3035;max-width:640px;}
.accent-text{color:var(--accent);}
.btn{display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:white;padding:13px 28px;font-weight:600;font-size:14px;cursor:pointer;border:none;margin-top:24px;transition:all 0.2s;letter-spacing:.03em;}
.btn:hover{background:#a8382a;transform:translateY(-1px);}

/* ─── SLIDE 1: HERO ─── */
#s1{
  background:var(--ink);
  background-image:
    radial-gradient(ellipse at 50% 0%, rgba(201,70,46,0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 0% 100%, rgba(232,160,48,0.08) 0%, transparent 40%);
}
.day-number{font-family:'Playfair Display',serif;font-size:clamp(100px,20vw,200px);font-weight:900;color:rgba(255,255,255,0.04);position:absolute;right:-20px;top:50%;transform:translateY(-50%);line-height:1;pointer-events:none;user-select:none;}
.theme-pill{display:inline-flex;gap:10px;align-items:center;border:1px solid rgba(201,70,46,0.5);padding:10px 20px;margin-bottom:32px;font-size:13px;color:#e0c8c0;font-style:italic;}
.hero-stat-row{display:flex;gap:32px;margin-top:36px;flex-wrap:wrap;}
.hero-stat{text-align:left;}
.hero-stat-num{font-family:'Playfair Display',serif;font-size:48px;font-weight:900;line-height:1;color:var(--accent);}
.hero-stat-label{font-size:12px;color:rgba(255,255,255,0.4);letter-spacing:.08em;text-transform:uppercase;margin-top:4px;}

/* ─── SLIDE 2: JOURNEY MAP ─── */
#s2{background:#f5f0ea;}
.journey-track{display:flex;align-items:center;gap:0;margin-top:40px;max-width:860px;width:100%;overflow-x:auto;padding-bottom:16px;}
.jstep{display:flex;flex-direction:column;align-items:center;flex:1;min-width:100px;opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;}
.jstep.show{opacity:1;transform:translateY(0);}
.jnode{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:18px;font-weight:900;}
.jnode.done{background:rgba(201,70,46,0.15);color:var(--accent);border:2px solid var(--accent);}
.jnode.current{background:var(--accent);color:white;box-shadow:0 0 0 4px rgba(201,70,46,0.2);}
.jnode.upcoming{background:white;color:var(--muted);border:2px solid #ddd;}
.jconnect{flex:1;height:2px;margin-top:-26px;z-index:1;}
.jlabel{font-size:11px;font-weight:600;margin-top:10px;text-align:center;color:var(--muted);letter-spacing:.05em;max-width:80px;line-height:1.3;}
.jlabel.done-label{color:rgba(201,70,46,0.6);}
.jlabel.now{color:var(--accent);font-weight:700;}

/* ─── SLIDE 3: THE PROBLEM WITH CALM PRACTICE ─── */
#s3{background:var(--cream);}
.calm-vs-load{display:flex;gap:2px;max-width:840px;width:100%;margin-top:32px;}
.cvl-side{flex:1;padding:0;}
.cvl-header{padding:16px 24px;font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;text-align:center;}
.cvl-side.calm .cvl-header{background:#e8f0e4;color:var(--safe);}
.cvl-side.load .cvl-header{background:#fdeee9;color:var(--accent);}
.cvl-body{padding:0;}
.cvl-row{display:flex;align-items:center;gap:0;}
.cvl-cell{flex:1;padding:14px 20px;font-size:14px;border-bottom:1px solid rgba(26,16,24,0.05);}
.cvl-side.calm .cvl-cell{background:white;color:var(--muted);}
.cvl-side.load .cvl-cell{background:#fffaf8;color:var(--ink);font-weight:500;}
.cvl-icon{width:40px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px;padding:14px 0;background:#f8f4f0;border-bottom:1px solid rgba(26,16,24,0.05);}
.cvl-reveal{opacity:0;transform:translateX(-10px);transition:opacity 0.4s ease,transform 0.4s ease;}
.cvl-reveal.show{opacity:1;transform:translateX(0);}

/* ─── SLIDE 4: WHAT GETS LOADED ─── */
#s4{background:var(--ink);}
/* SVG body figure built inline */
.load-diagram{display:flex;gap:40px;align-items:flex-start;max-width:840px;width:100%;margin-top:28px;flex-wrap:wrap;}
.body-figure{flex-shrink:0;}
.load-legend{flex:1;min-width:260px;}
.load-item{
  display:flex;align-items:flex-start;gap:14px;padding:14px 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
  opacity:0;transform:translateX(20px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.load-item.show{opacity:1;transform:translateX(0);}
.load-item:last-child{border:none;}
.load-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:5px;}
.load-title{font-size:13px;font-weight:700;color:var(--cream);margin-bottom:3px;}
.load-desc{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.5;}
.load-meter{
  height:4px;background:rgba(255,255,255,0.06);
  border-radius:2px;margin-top:6px;overflow:hidden;
}
.load-meter-fill{height:100%;border-radius:2px;width:0;transition:width 1.2s cubic-bezier(.25,1,.5,1);}

/* ─── SLIDE 5: WHY MARCHING ─── */
#s5{background:#f5f0ea;}
.march-why{display:flex;flex-direction:column;gap:16px;margin-top:32px;max-width:820px;width:100%;}
.mw-row{
  display:flex;align-items:flex-start;gap:20px;padding:20px 24px;
  background:white;position:relative;overflow:hidden;
  opacity:0;transform:translateY(12px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.mw-row.show{opacity:1;transform:translateY(0);}
.mw-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;}
.mw-row:nth-child(1)::before{background:var(--safe);}
.mw-row:nth-child(2)::before{background:var(--accent2);}
.mw-row:nth-child(3)::before{background:var(--accent);}
.mw-row:nth-child(4)::before{background:#8b1a0a;}
.mw-icon{font-size:28px;flex-shrink:0;margin-top:2px;}
.mw-row h4{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;margin-bottom:6px;}
.mw-row p{font-size:14px;color:var(--muted);max-width:none;margin:0;line-height:1.6;}
.mw-row strong{color:var(--ink);}

/* ─── SLIDE 6: THE SIGNAL ─── */
#s6{background:var(--ink);}
.signal-intro{
  font-family:'Playfair Display',serif;
  font-size:clamp(22px,3.5vw,38px);font-weight:700;
  color:var(--cream);line-height:1.3;max-width:720px;margin-bottom:32px;
}
.signal-intro span{color:var(--accent);}
.feet-visual{max-width:820px;width:100%;margin-top:12px;}
.fv-row{
  display:flex;align-items:center;gap:16px;padding:18px 0;
  border-bottom:1px solid rgba(255,255,255,0.05);
  opacity:0;transform:translateX(-16px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.fv-row.show{opacity:1;transform:translateX(0);}
.fv-row:last-child{border:none;}
.fv-icon{font-size:28px;flex-shrink:0;width:48px;text-align:center;}
.fv-state{
  font-size:12px;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;margin-bottom:4px;
}
.fv-row:nth-child(1) .fv-state{color:var(--safe);}
.fv-row:nth-child(2) .fv-state{color:var(--accent2);}
.fv-row:nth-child(3) .fv-state{color:var(--accent);}
.fv-desc{font-size:14px;color:rgba(255,255,255,0.6);line-height:1.5;}
.fv-beat{
  margin-left:auto;flex-shrink:0;
  display:flex;gap:4px;align-items:flex-end;height:32px;
}
.beat-bar{width:6px;border-radius:3px;background:rgba(255,255,255,0.1);}
.fv-row:nth-child(1) .beat-bar{background:var(--safe);animation:beatGreen 0.5s ease infinite alternate;}
.fv-row:nth-child(2) .beat-bar{background:var(--accent2);animation:beatAmber 0.7s ease infinite alternate;}
.fv-row:nth-child(3) .beat-bar{background:var(--accent);}
@keyframes beatGreen{0%{height:16px}100%{height:28px}}
@keyframes beatAmber{0%{height:8px}100%{height:20px}}
.beat-bar:nth-child(1){animation-delay:0s;}
.beat-bar:nth-child(2){animation-delay:.1s;}
.beat-bar:nth-child(3){animation-delay:.2s;}
.beat-bar:nth-child(4){animation-delay:.3s;}
.beat-bar:nth-child(5){animation-delay:.15s;}

/* ─── SLIDE 7: THE EXERCISE (STEP BY STEP) ─── */
#s7{background:#fffdf8;}
.exercise-track{
  display:flex;flex-direction:column;gap:0;
  max-width:820px;width:100%;margin-top:32px;
  position:relative;padding-left:56px;
}
.exercise-track::before{
  content:'';position:absolute;left:20px;top:12px;bottom:12px;width:2px;
  background:linear-gradient(to bottom,var(--safe),var(--accent2),var(--accent),#8b1a0a);
}
.ex-step{
  position:relative;margin-bottom:28px;
  opacity:0;transform:translateX(20px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.ex-step.show{opacity:1;transform:translateX(0);}
.ex-node{
  position:absolute;left:-47px;top:6px;
  width:28px;height:28px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'Playfair Display',serif;font-size:13px;font-weight:900;color:white;z-index:2;
}
.ex-step:nth-child(1) .ex-node{background:var(--safe);}
.ex-step:nth-child(2) .ex-node{background:var(--accent2);}
.ex-step:nth-child(3) .ex-node{background:var(--accent);}
.ex-step:nth-child(4) .ex-node{background:#8b1a0a;}
.ex-phase{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.ex-step:nth-child(1) .ex-phase{color:var(--safe);}
.ex-step:nth-child(2) .ex-phase{color:var(--accent2);}
.ex-step:nth-child(3) .ex-phase{color:var(--accent);}
.ex-step:nth-child(4) .ex-phase{color:#c0402a;}
.ex-step h4{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;margin-bottom:8px;}
.ex-step p{font-size:14px;color:var(--muted);max-width:none;margin:0;line-height:1.7;}
.ex-step strong{color:var(--ink);}
.ex-prompts{
  display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;
}
.ex-prompt-pill{
  background:#f5f0ea;border:1px solid #e8e0d4;
  padding:6px 14px;font-size:13px;color:var(--ink);
  font-style:italic;cursor:pointer;transition:all 0.2s;
}
.ex-prompt-pill:hover,.ex-prompt-pill.picked{background:var(--ink);color:var(--cream);border-color:var(--ink);}
.ex-rules{
  margin-top:12px;display:flex;flex-direction:column;gap:6px;
}
.ex-rule{
  display:flex;align-items:center;gap:10px;
  font-size:13px;color:var(--muted);
}
.ex-rule::before{content:'→';color:var(--accent);font-weight:700;}

/* ─── SLIDE 8: THE TIMER SLIDE ─── */
#s8{
  background:var(--ink);
  background-image:radial-gradient(ellipse at 50% 50%, rgba(201,70,46,0.1) 0%, transparent 60%);
}
.timer-core{text-align:center;max-width:600px;width:100%;}
.timer-label{font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:16px;}
.timer-display{
  font-family:'Playfair Display',serif;
  font-size:clamp(80px,16vw,160px);font-weight:900;
  color:var(--cream);line-height:1;
  transition:color 0.3s;
  text-shadow:0 0 60px rgba(201,70,46,0.2);
}
.timer-display.running{color:var(--accent2);}
.timer-display.warning{color:var(--accent);animation:timerPulse 0.5s ease infinite alternate;}
@keyframes timerPulse{0%{opacity:0.7}100%{opacity:1}}
.timer-sub{font-size:14px;color:rgba(255,255,255,0.4);margin-top:8px;min-height:24px;}
.timer-march{
  margin-top:24px;display:flex;justify-content:center;gap:8px;
  align-items:flex-end;height:48px;
}
.march-beat{
  width:10px;border-radius:5px;background:rgba(255,255,255,0.12);
  transition:height 0.15s ease,background 0.3s;
}
.timer-btns{display:flex;gap:12px;justify-content:center;margin-top:28px;flex-wrap:wrap;}
.timer-btn{
  padding:12px 28px;border:none;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;
  letter-spacing:.03em;transition:all 0.2s;
}
.timer-btn.start{background:var(--accent);color:white;}
.timer-btn.start:hover{background:#a8382a;}
.timer-btn.reset{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);}
.timer-btn.reset:hover{background:rgba(255,255,255,0.15);}
.timer-duration{display:flex;gap:8px;justify-content:center;margin-bottom:20px;}
.dur-btn{
  padding:7px 16px;border:1px solid rgba(255,255,255,0.2);
  background:transparent;color:rgba(255,255,255,0.5);
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;
}
.dur-btn.active{background:rgba(255,255,255,0.12);color:var(--cream);border-color:rgba(255,255,255,0.4);}
.timer-cue{
  margin-top:20px;padding:14px 20px;
  background:rgba(255,255,255,0.04);border-left:2px solid var(--accent2);
  font-size:14px;color:rgba(255,255,255,0.6);line-height:1.6;
  min-height:56px;
}

/* ─── SLIDE 9: WHAT BREAKS FIRST — DIAGNOSTIC ─── */
#s9{background:#f5f0ea;}
.diagnostic{max-width:820px;width:100%;margin-top:28px;}
.diag-intro{font-size:16px;color:var(--ink);max-width:680px;line-height:1.7;margin-bottom:28px;}
.diag-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.diag-card{
  background:white;padding:24px;
  border-top:3px solid transparent;cursor:pointer;
  transition:all 0.25s ease;
  opacity:0;transform:translateY(12px);
  transition:opacity 0.4s ease,transform 0.4s ease,border-color 0.25s,box-shadow 0.25s;
  position:relative;
}
.diag-card.show{opacity:1;transform:translateY(0);}
.diag-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.08);}
.diag-card.selected{box-shadow:0 4px 20px rgba(0,0,0,0.1);}
.diag-card:nth-child(1){border-color:#c8c0b8;}
.diag-card:nth-child(2){border-color:#c8c0b8;}
.diag-card:nth-child(3){border-color:#c8c0b8;}
.diag-card:nth-child(4){border-color:#c8c0b8;}
.diag-card.selected:nth-child(1){border-color:var(--accent);}
.diag-card.selected:nth-child(2){border-color:var(--accent2);}
.diag-card.selected:nth-child(3){border-color:#2d6e8e;}
.diag-card.selected:nth-child(4){border-color:var(--safe);}
.diag-icon{font-size:32px;margin-bottom:10px;}
.diag-card h4{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;margin-bottom:8px;}
.diag-card p{font-size:13px;color:var(--muted);max-width:none;margin:0;line-height:1.6;}
.diag-what{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:10px;padding-top:10px;border-top:1px solid #f0ece8;}
.diag-result{
  margin-top:20px;padding:20px 24px;background:var(--ink);max-width:820px;width:100%;
  display:none;
}
.diag-result.visible{display:block;}
.diag-result p{font-size:15px;color:rgba(255,255,255,0.75);max-width:none;margin:0;line-height:1.7;}
.diag-result strong{color:var(--accent2);}

/* ─── SLIDE 10: THE CAPACITY EDGE ─── */
#s10{background:var(--ink);}
.capacity-visual{max-width:820px;width:100%;margin-top:32px;}
.cap-bar-label{
  font-size:11px;font-weight:700;letter-spacing:.15em;
  text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:20px;
}
.cap-zone{position:relative;margin-bottom:24px;}
.cap-zone-label{font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;}
.cap-zone:nth-child(1) .cap-zone-label{color:var(--safe);}
.cap-zone:nth-child(2) .cap-zone-label{color:var(--accent2);}
.cap-zone:nth-child(3) .cap-zone-label{color:var(--accent);}
.cap-track{height:36px;background:rgba(255,255,255,0.04);border-radius:2px;overflow:hidden;position:relative;}
.cap-fill{height:100%;border-radius:2px;width:0;transition:width 1.4s cubic-bezier(.25,1,.5,1);display:flex;align-items:center;padding-left:16px;}
.cap-zone:nth-child(1) .cap-fill{background:linear-gradient(to right,rgba(74,140,92,0.4),rgba(74,140,92,0.7));}
.cap-zone:nth-child(2) .cap-fill{background:linear-gradient(to right,rgba(232,160,48,0.4),rgba(232,160,48,0.7));}
.cap-zone:nth-child(3) .cap-fill{background:linear-gradient(to right,rgba(201,70,46,0.4),rgba(201,70,46,0.7));}
.cap-fill-label{font-size:12px;font-weight:600;color:white;white-space:nowrap;}
.cap-desc{font-size:13px;color:rgba(255,255,255,0.45);margin-top:6px;line-height:1.5;}
.cap-edge-line{
  margin-top:8px;padding:4px 14px;
  background:rgba(201,70,46,0.15);border:1px dashed rgba(201,70,46,0.4);
  font-size:12px;color:var(--accent);display:inline-block;
}
.capacity-quote{
  margin-top:28px;padding:22px 28px;
  background:rgba(255,255,255,0.04);border-left:3px solid var(--accent2);
  max-width:820px;
}
.capacity-quote p{font-family:'Playfair Display',serif;font-size:18px;font-style:italic;color:var(--cream);line-height:1.5;max-width:none;margin:0;}

/* ─── SLIDE 11: COMMUNITY POSTS ─── */
#s11{background:var(--ink);}
