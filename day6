<script>
  const totalSlides = 13;
  let current = 0;
  let chosenPrompt = '';

  // ─── NAV ───
  const pillsEl = document.getElementById('pills');
  for (let i = 0; i < totalSlides; i++) {
    const p = document.createElement('div');
    p.className = 'pill' + (i === 0 ? ' active' : '');
    p.onclick = () => goTo(i);
    pillsEl.appendChild(p);
  }

  const streakRow = document.getElementById('streakRow');
  for (let d = 1; d <= 30; d++) {
    const el = document.createElement('div');
    if (d <= 5) el.className = 'streak-day done';
    else if (d === 6) el.className = 'streak-day lit';
    else el.className = 'streak-day';
    el.textContent = d;
    streakRow.appendChild(el);
  }

  function goTo(idx) {
    if (idx < 0 || idx >= totalSlides) return;
    const slides = document.querySelectorAll('.slide');
    slides[current].classList.remove('active');
    current = idx;
    slides[current].classList.add('active');
    updateUI(); triggerAnimations(idx);
    slides[current].scrollIntoView({ behavior: 'auto' });
  }
  function go(dir) { goTo(current + dir); }

  function updateUI() {
    document.getElementById('prog').style.width = ((current + 1) / totalSlides * 100) + '%';
    document.getElementById('counter').textContent = (current + 1) + ' / ' + totalSlides;
    document.getElementById('nav-prev').style.opacity = current === 0 ? '0.3' : '1';
    document.getElementById('nav-next').style.opacity = current === totalSlides - 1 ? '0.3' : '1';
    pillsEl.querySelectorAll('.pill').forEach((p, i) => {
      p.classList.remove('active', 'done');
      if (i === current) p.classList.add('active');
      else if (i < current) p.classList.add('done');
    });
  }

  // ─── ANIMATIONS ───
  let animated = new Set();
  function triggerAnimations(idx) {
    if (animated.has(idx)) return; animated.add(idx);

    if (idx === 1) {
      document.querySelectorAll('#journeyTrack .jstep')
        .forEach((s, i) => setTimeout(() => s.classList.add('show'), i * 100));
    }
    if (idx === 2) {
      setTimeout(() => {
        document.querySelectorAll('#calmVsLoad .cvl-reveal')
          .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 80));
      }, 300);
    }
    if (idx === 3) {
      setTimeout(() => {
        document.querySelectorAll('#loadLegend .load-item').forEach((el, i) => {
          setTimeout(() => {
            el.classList.add('show');
            el.querySelector('.load-meter-fill').style.width = el.querySelector('.load-meter-fill').dataset.w + '%';
          }, i * 180);
        });
        // Animate the SVG body
        animateBody();
      }, 300);
    }
    if (idx === 4) {
      document.querySelectorAll('#marchWhy .mw-row')
        .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 150));
    }
    if (idx === 5) {
      document.querySelectorAll('#feetVisual .fv-row')
        .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 200));
    }
    if (idx === 6) {
      document.querySelectorAll('#exerciseTrack .ex-step')
        .forEach((s, i) => setTimeout(() => s.classList.add('show'), i * 180));
    }
    if (idx === 8) {
      document.querySelectorAll('#diagGrid .diag-card')
        .forEach((c, i) => setTimeout(() => c.classList.add('show'), i * 120));
    }
    if (idx === 9) {
      setTimeout(() => {
        document.querySelectorAll('#capVisual .cap-fill')
          .forEach((f, i) => setTimeout(() => f.style.width = f.dataset.w + '%', i * 250));
      }, 400);
    }
  }

  // ─── SVG BODY ANIMATION ───
  function animateBody() {
    let legUp = false;
    setInterval(() => {
      const lL = document.getElementById('legLeft');
      const lR = document.getElementById('legRight');
      const fL = document.getElementById('footLeft');
      const fR = document.getElementById('footRight');
      if (!lL) return;
      if (legUp) {
        lL.setAttribute('d', 'M66 165 Q60 200 58 240');
        lR.setAttribute('d', 'M94 165 Q100 190 102 225');
        fL.setAttribute('cy', '244'); fR.setAttribute('cy', '229');
      } else {
        lL.setAttribute('d', 'M66 165 Q60 190 58 225');
        lR.setAttribute('d', 'M94 165 Q100 200 102 240');
        fL.setAttribute('cy', '229'); fR.setAttribute('cy', '244');
      }
      legUp = !legUp;
    }, 450);
  }

  // ─── PROMPT PICKER ───
  function pickPrompt(el) {
    document.querySelectorAll('.ex-prompt-pill').forEach(p => p.classList.remove('picked'));
    el.classList.add('picked');
    chosenPrompt = el.textContent;
    document.getElementById('timerCue').textContent = 'Your prompt: ' + chosenPrompt;
  }

  // ─── TIMER ───
  let timerDuration = 30;
  let timerRemaining = 30;
  let timerInterval = null;
  let timerRunning = false;
  let marchInterval = null;

  const cues = {
    start: ['Feet moving. Core message first.', 'Start marching. Lead with your point.', 'Moving. Structure holding. Go.'],
    mid:   ['Keep the rhythm. Explain section now.', 'Feet steady. One reason. Make it count.', 'Half way. Rhythm steady. Explain is on.'],
    end:   ['Own the ending. Do not trail off.', 'Land it. Finish the sentence. Keep marching.', 'Ending. Own it completely. Then stop.'],
    done:  ['Rep complete. What broke first?', 'Done. Reflect immediately — what held?', 'Finished. Check your feet. Check the ending.']
  };
  function randCue(stage) { const a = cues[stage]; return a[Math.floor(Math.random()*a.length)]; }

  function setDuration(s, btn) {
    timerDuration = s; timerRemaining = s;
    document.querySelectorAll('.dur-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('timerDisplay').textContent = '0:' + String(s).padStart(2,'0');
    if (timerRunning) resetTimer();
  }

  function toggleTimer() {
    if (timerRunning) { pauseTimer(); } else { startTimer(); }
  }

  function startTimer() {
    timerRunning = true;
    document.getElementById('startBtn').textContent = '⏸ Pause';
    document.getElementById('timerDisplay').classList.add('running');
    document.getElementById('timerSub').textContent = 'Marching. Speaking. Holding structure.';
    document.getElementById('timerCue').textContent = randCue('start');
    startMarchVisual();
    timerInterval = setInterval(() => {
      timerRemaining--;
      const pct = timerRemaining / timerDuration;
      const m = Math.floor(timerRemaining / 60);
      const s = timerRemaining % 60;
      document.getElementById('timerDisplay').textContent = m + ':' + String(s).padStart(2,'0');

      if (pct < 0.25) {
        document.getElementById('timerDisplay').classList.remove('running');
        document.getElementById('timerDisplay').classList.add('warning');
        document.getElementById('timerCue').textContent = randCue('end');
      } else if (pct < 0.5) {
        document.getElementById('timerCue').textContent = randCue('mid');
      }

      if (timerRemaining <= 0) {
        clearInterval(timerInterval); stopMarchVisual();
        document.getElementById('timerDisplay').textContent = '0:00';
        document.getElementById('timerDisplay').classList.remove('running','warning');
        document.getElementById('timerSub').textContent = 'Rep complete. Reflect immediately.';
        document.getElementById('timerCue').textContent = randCue('done');
        document.getElementById('startBtn').textContent = '▶ Start';
        timerRunning = false; timerRemaining = timerDuration;
        setTimeout(() => goTo(8), 1800);
      }
    }, 1000);
  }

  function pauseTimer() {
    timerRunning = false;
    clearInterval(timerInterval); stopMarchVisual();
    document.getElementById('startBtn').textContent = '▶ Resume';
    document.getElementById('timerDisplay').classList.remove('running','warning');
    document.getElementById('timerSub').textContent = 'Paused.';
  }

  function resetTimer() {
    timerRunning = false;
    clearInterval(timerInterval); stopMarchVisual();
    timerRemaining = timerDuration;
    const s = timerDuration;
    document.getElementById('timerDisplay').textContent = '0:' + String(s).padStart(2,'0');
    document.getElementById('timerDisplay').classList.remove('running','warning');
    document.getElementById('timerSub').textContent = 'Ready. Choose your prompt. Build your CEO. Then go.';
    document.getElementById('timerCue').textContent = chosenPrompt ? 'Your prompt: ' + chosenPrompt : 'Your selected prompt will appear here.';
    document.getElementById('startBtn').textContent = '▶ Start';
  }

  let marchPhase = 0;
  function startMarchVisual() {
    const heights = [40, 24, 40, 16, 40, 24, 40, 16];
    marchInterval = setInterval(() => {
      for (let i = 1; i <= 8; i++) {
        const bar = document.getElementById('mb' + i);
        if (bar) {
          const h = heights[(i + marchPhase) % heights.length];
          bar.style.height = h + 'px';
          bar.style.background = marchPhase % 2 === 0 && i <= 4
            ? 'rgba(232,160,48,0.8)' : 'rgba(201,70,46,0.6)';
        }
      }
      marchPhase++;
    }, 200);
  }
  function stopMarchVisual() {
    clearInterval(marchInterval);
    for (let i = 1; i <= 8; i++) {
      const bar = document.getElementById('mb' + i);
      if (bar) { bar.style.height = '8px'; bar.style.background = 'rgba(255,255,255,0.12)'; }
    }
  }

  // ─── DIAGNOSTIC ───
  const diagMessages = {
    breath: '<strong>Breath broke first.</strong> Your physical activation overtook your vocal control. Next rep: take one deliberate breath between each sentence. Speak on the exhale. The rhythm will slow your pace without you deciding to slow it.',
    rhythm: '<strong>Rhythm broke first.</strong> Your feet were funding the speech. That is exactly the right kind of overload — it means your cognitive load hit its ceiling. Next rep: use a simpler prompt. Keep the feet moving no matter what happens to the words.',
    structure: '<strong>Structure broke first.</strong> The CEO framework dissolved under load. The core message drifted. The explain went long. The ending never arrived. Next rep: write out all three parts before you start. Have them in front of you if you need to.',
    clarity: '<strong>Clarity broke first.</strong> The words came out but they had no weight. Next rep: make your core message a sharper sentence. One specific claim — not a theme. If it could apply to anything, it is not specific enough.'
  };

  function diagSelect(el, type) {
    document.querySelectorAll('.diag-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    const result = document.getElementById('diagResult');
    result.innerHTML = '<p>' + diagMessages[type] + '</p>';
    result.classList.add('visible');
  }

  // ─── TASK CHECKS ───
  function checkTask(el) {
    el.classList.toggle('checked');
    el.textContent = el.classList.contains('checked') ? '✓' : '';
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === ' ') go(1);
    if (e.key === 'ArrowLeft') go(-1);
  });

  goTo(0);
</script>
