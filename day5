<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Day 5 — How to Stop Rushing</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1018;
  --cream: #faf6f0;
  --accent: #c9462e;
  --accent2: #e8a030;
  --muted: #7a6e6a;
  --safe: #4a8c5c;
  --border: rgba(26,16,24,0.08);
  --ceo-c: #c9462e;
  --ceo-e: #2d6e8e;
  --ceo-o: #4a8c5c;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body {
  background:var(--cream); color:var(--ink);
  font-family:'DM Sans',sans-serif; font-size:16px;
  line-height:1.7; overflow-x:hidden;
}
.slide {
  min-height:100vh; width:100%;
  display:flex; flex-direction:column;
  justify-content:center; align-items:center;
  padding:80px 40px 80px;
  position:relative; overflow:hidden;
  opacity:0; transform:translateY(24px);
  transition:opacity 0.8s ease, transform 0.8s ease;
}
.slide.active{opacity:1;transform:translateY(0);}
header {
  position:fixed;top:0;left:0;right:0;height:56px;
  background:rgba(250,246,240,0.96);backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 32px;z-index:200;
}
.logo{font-family:'Playfair Display',serif;font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);}
.day-badge{background:var(--ink);color:var(--cream);font-size:11px;font-weight:600;letter-spacing:.1em;padding:5px 14px;text-transform:uppercase;}
.nav-pills{display:flex;gap:6px;align-items:center;}
.pill{width:28px;height:5px;border-radius:3px;background:#d0c8c0;cursor:pointer;transition:all 0.3s ease;}
.pill.active{background:var(--accent);width:40px;}
.pill.done{background:var(--accent2);}
#prog{position:fixed;top:56px;left:0;height:2px;background:var(--accent);z-index:201;transition:width 0.4s ease;}
.nav-arrow{position:fixed;bottom:32px;background:var(--ink);color:var(--cream);border:none;cursor:pointer;width:48px;height:48px;display:flex;align-items:center;justify-content:center;font-size:18px;z-index:200;transition:all 0.2s ease;}
.nav-arrow:hover{background:var(--accent);}
#nav-prev{left:40px;}#nav-next{right:40px;}
.slide-counter{position:fixed;bottom:38px;left:50%;transform:translateX(-50%);font-size:12px;font-weight:600;color:var(--muted);z-index:200;letter-spacing:.1em;}
.label{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
h1{font-family:'Playfair Display',serif;font-size:clamp(40px,7vw,80px);font-weight:900;line-height:1.05;margin-bottom:24px;}
h2{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);font-weight:700;line-height:1.15;margin-bottom:20px;}
.lead{font-size:18px;line-height:1.65;color:#3d3035;max-width:640px;}
.accent-text{color:var(--accent);}
.btn{display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:white;padding:13px 28px;font-weight:600;font-size:14px;cursor:pointer;border:none;margin-top:24px;transition:all 0.2s;letter-spacing:.03em;}
.btn:hover{background:#a8382a;transform:translateY(-1px);}

/* ─── SLIDE 1: HERO ─── */
#s1{
  background:var(--ink);
  background-image:
    radial-gradient(ellipse at 60% 10%, rgba(201,70,46,0.2) 0%, transparent 45%),
    radial-gradient(ellipse at 5% 90%, rgba(232,160,48,0.08) 0%, transparent 40%);
}
.day-number{font-family:'Playfair Display',serif;font-size:clamp(100px,20vw,200px);font-weight:900;color:rgba(255,255,255,0.04);position:absolute;right:-20px;top:50%;transform:translateY(-50%);line-height:1;pointer-events:none;user-select:none;}
.theme-pill{display:inline-flex;gap:10px;align-items:center;border:1px solid rgba(201,70,46,0.4);padding:10px 20px;margin-bottom:32px;font-size:13px;color:#e0c8c0;font-style:italic;}

/* ─── SLIDE 2: JOURNEY MAP ─── */
#s2{background:#f5f0ea;}
.journey-track{display:flex;align-items:center;gap:0;margin-top:40px;max-width:860px;width:100%;overflow-x:auto;padding-bottom:16px;}
.jstep{display:flex;flex-direction:column;align-items:center;flex:1;min-width:100px;opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease;}
.jstep.show{opacity:1;transform:translateY(0);}
.jnode{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:18px;font-weight:900;}
.jnode.done{background:rgba(201,70,46,0.15);color:var(--accent);border:2px solid var(--accent);}
.jnode.current{background:var(--accent);color:white;box-shadow:0 0 0 4px rgba(201,70,46,0.2);}
.jnode.upcoming{background:white;color:var(--muted);border:2px solid #ddd;}
.jconnect{flex:1;height:2px;margin-top:-26px;z-index:1;}
.jlabel{font-size:11px;font-weight:600;margin-top:10px;text-align:center;color:var(--muted);letter-spacing:.05em;max-width:80px;line-height:1.3;}
.jlabel.done-label{color:rgba(201,70,46,0.6);}
.jlabel.now{color:var(--accent);font-weight:700;}

/* ─── SLIDE 3: RUSHING IS IDENTITY ─── */
#s3{background:var(--ink);}
.rush-scene{
  max-width:820px;width:100%;margin-top:32px;
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.08);
  padding:32px;position:relative;overflow:hidden;
}
.rush-scene::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%, rgba(201,70,46,0.08) 0%, transparent 60%);
  pointer-events:none;
}
.rush-transcript{
  font-family:'DM Mono',monospace;font-size:14px;
  line-height:2;color:rgba(255,255,255,0.5);
  position:relative;
}
.rush-word{
  display:inline;transition:color 0.15s ease;
  cursor:default;
}
.rush-word.fast{color:rgba(201,70,46,0.8);animation:flicker 0.3s ease infinite alternate;}
.rush-word.trail{color:rgba(255,255,255,0.2);}
.rush-word.gone{color:rgba(255,255,255,0.1);text-decoration:line-through;text-decoration-color:rgba(201,70,46,0.3);}
@keyframes flicker{0%{opacity:0.7}100%{opacity:1}}
.rush-pulse{
  display:inline-block;width:10px;height:10px;border-radius:50%;
  background:var(--accent);margin-left:6px;
  animation:pulse 0.5s ease infinite alternate;
  vertical-align:middle;
}
@keyframes pulse{0%{transform:scale(0.8);opacity:0.5}100%{transform:scale(1.2);opacity:1}}
.rush-caption{
  margin-top:20px;padding:16px 20px;
  background:rgba(201,70,46,0.1);border-left:3px solid var(--accent);
  font-size:13px;color:rgba(255,255,255,0.6);line-height:1.7;
}
.rush-reasons{display:flex;flex-direction:column;gap:0;margin-top:28px;max-width:820px;}
.rush-reason{
  display:flex;align-items:flex-start;gap:16px;padding:14px 0;
  border-bottom:1px solid rgba(255,255,255,0.05);
  opacity:0;transform:translateX(-16px);
  transition:opacity 0.4s ease,transform 0.4s ease;
}
.rush-reason.show{opacity:1;transform:translateX(0);}
.rush-reason:last-child{border:none;}
.rush-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:8px;}
.rush-reason p{font-size:14px;color:rgba(255,255,255,0.65);max-width:none;margin:0;line-height:1.6;}
.rush-reason strong{color:var(--cream);}

/* ─── SLIDE 4: THE MOMENT IT BREAKS ─── */
#s4{background:#f5f0ea;}
.break-timeline{max-width:820px;width:100%;margin-top:36px;position:relative;padding-left:32px;}
.break-timeline::before{
  content:'';position:absolute;left:8px;top:0;bottom:0;width:2px;
  background:linear-gradient(to bottom,var(--safe),var(--accent2),var(--accent));
}
.break-moment{
  position:relative;margin-bottom:28px;
  opacity:0;transform:translateX(20px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.break-moment.show{opacity:1;transform:translateX(0);}
.break-moment::before{
  content:'';position:absolute;left:-28px;top:8px;
  width:14px;height:14px;border-radius:50%;border:2px solid white;
}
.break-moment:nth-child(1)::before{background:var(--safe);}
.break-moment:nth-child(2)::before{background:var(--accent2);}
.break-moment:nth-child(3)::before{background:var(--accent);}
.break-moment:nth-child(4)::before{background:#8B1A0A;}
.break-phase{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:6px;}
.break-moment:nth-child(1) .break-phase{color:var(--safe);}
.break-moment:nth-child(2) .break-phase{color:var(--accent2);}
.break-moment:nth-child(3) .break-phase{color:var(--accent);}
.break-moment:nth-child(4) .break-phase{color:#c0402a;}
.break-moment h4{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;margin-bottom:6px;}
.break-moment p{font-size:14px;color:var(--muted);max-width:none;margin:0;line-height:1.65;}
.break-moment em{color:var(--ink);font-style:normal;font-weight:600;}

/* ─── SLIDE 5: CEO INTRO ─── */
#s5{background:var(--ink);}
.ceo-wordmark{
  font-family:'Playfair Display',serif;
  font-size:clamp(80px,14vw,160px);font-weight:900;
  letter-spacing:.08em;line-height:1;
  position:relative;display:inline-block;margin-bottom:8px;
}
.ceo-c{color:var(--ceo-c);}
.ceo-e{color:var(--ceo-e);}
.ceo-o{color:var(--ceo-o);}
.ceo-sub{
  display:flex;gap:40px;margin-top:4px;margin-bottom:32px;
  flex-wrap:wrap;
}
.ceo-sub-item{font-size:13px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;}
.ceo-sub-item.c{color:var(--ceo-c);}
.ceo-sub-item.e{color:var(--ceo-e);}
.ceo-sub-item.o{color:var(--ceo-o);}
.ceo-def{
  font-family:'Playfair Display',serif;
  font-size:clamp(18px,2.5vw,26px);font-weight:700;
  color:var(--cream);line-height:1.4;max-width:680px;
  opacity:0;transform:translateY(16px);
  transition:opacity 0.7s ease,transform 0.7s ease;
}
.ceo-def.show{opacity:1;transform:translateY(0);}
.ceo-def span{color:var(--accent2);font-style:italic;}

/* ─── SLIDE 6: C — CORE MESSAGE ─── */
#s6{background:var(--cream);}
.ceo-step-hero{
  display:flex;align-items:flex-start;gap:28px;
  max-width:820px;width:100%;margin-bottom:28px;
}
.ceo-letter-big{
  font-family:'Playfair Display',serif;
  font-size:clamp(80px,12vw,120px);font-weight:900;
  line-height:.9;flex-shrink:0;
}
.ceo-letter-big.c{color:var(--ceo-c);}
.ceo-letter-big.e{color:var(--ceo-e);}
.ceo-letter-big.o{color:var(--ceo-o);}
.ceo-step-title{padding-top:8px;}
.ceo-step-title .label{margin-bottom:4px;}
.ceo-step-title h2{margin-bottom:8px;}
.ceo-step-title p{font-size:16px;color:var(--muted);max-width:none;margin:0;}
.ceo-contrast{
  display:flex;gap:0;max-width:820px;width:100%;
  margin-top:4px;
}
.ceo-no{
  flex:1;background:#f5f0ea;padding:20px 24px;
  border-top:3px solid #c8c0b8;
}
.ceo-yes{
  flex:1;background:white;padding:20px 24px;
  border-top:3px solid var(--ceo-c);
}
.ceo-no-tag{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#a09890;margin-bottom:10px;}
.ceo-yes-tag{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--ceo-c);margin-bottom:10px;}
.ceo-no p,.ceo-yes p{font-size:14px;line-height:1.7;max-width:none;margin:0;}
.ceo-no p{color:var(--muted);font-style:italic;}
.ceo-yes p{color:var(--ink);font-weight:500;}
.ceo-tip{
  max-width:820px;width:100%;margin-top:16px;
  padding:14px 20px;background:white;
  border-left:3px solid var(--ceo-c);
  font-size:14px;color:var(--ink);line-height:1.65;
}

/* ─── SLIDE 7: E — EXPLAIN ─── */
#s7{background:#f5f0ea;}
.explain-phrases{
  display:flex;flex-direction:column;gap:10px;
  margin-top:24px;max-width:820px;width:100%;
}
.ep-row{
  display:flex;align-items:center;gap:16px;padding:14px 20px;
  background:white;border-left:3px solid var(--ceo-e);
  opacity:0;transform:translateX(-16px);
  transition:opacity 0.4s ease,transform 0.4s ease;
}
.ep-row.show{opacity:1;transform:translateX(0);}
.ep-phrase{
  font-family:'DM Mono',monospace;font-size:14px;
  font-weight:500;color:var(--ceo-e);flex-shrink:0;width:260px;
}
.ep-why{font-size:13px;color:var(--muted);}
.explain-rule{
  max-width:820px;width:100%;margin-top:16px;
  padding:16px 20px;background:var(--ink);
  display:flex;align-items:center;gap:16px;
  opacity:0;transition:opacity 0.6s ease;
}
.explain-rule.show{opacity:1;}
.explain-rule p{font-size:14px;color:rgba(255,255,255,0.7);max-width:none;margin:0;line-height:1.65;}
.explain-rule strong{color:var(--accent2);}

/* ─── SLIDE 8: O — OWN THE ENDING ─── */
#s8{background:var(--cream);}
.ending-types{
  display:flex;gap:16px;margin-top:28px;max-width:820px;width:100%;
  flex-wrap:wrap;
}
.ending-type{
  flex:1;min-width:220px;padding:24px;
  background:white;border-top:3px solid var(--ceo-o);
  opacity:0;transform:translateY(16px);
  transition:opacity 0.5s ease,transform 0.5s ease;
}
.ending-type.show{opacity:1;transform:translateY(0);}
.et-num{font-family:'Playfair Display',serif;font-size:36px;font-weight:900;color:rgba(74,140,92,0.15);line-height:1;margin-bottom:8px;}
.ending-type h4{font-size:15px;font-weight:700;margin-bottom:6px;color:var(--ceo-o);}
.ending-type p{font-size:13px;color:var(--muted);max-width:none;margin:0;line-height:1.6;}
.ending-type .eg{font-size:13px;color:var(--ink);font-style:italic;margin-top:8px;padding-top:8px;border-top:1px solid #f0ece8;max-width:none;}
.abandon-box{
  max-width:820px;width:100%;margin-top:20px;
  padding:18px 24px;background:#fff5f3;border-left:3px solid var(--accent);
  font-size:14px;color:var(--ink);line-height:1.7;
}
.abandon-box strong{color:var(--accent);}

/* ─── SLIDE 9: SIDE-BY-SIDE TRANSCRIPT ─── */
#s9{background:var(--ink);}
.transcript-compare{
  display:flex;gap:2px;max-width:900px;width:100%;margin-top:32px;
}
.tc-side{flex:1;padding:28px;}
.tc-side.weak{background:rgba(255,255,255,0.03);border-top:3px solid rgba(201,70,46,0.4);}
.tc-side.strong{background:rgba(74,140,92,0.07);border-top:3px solid var(--ceo-o);}
.tc-tag{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:16px;}
.tc-side.weak .tc-tag{color:rgba(201,70,46,0.7);}
.tc-side.strong .tc-tag{color:var(--ceo-o);}
.tc-text{
  font-family:'DM Mono',monospace;font-size:13px;
  line-height:2;color:rgba(255,255,255,0.5);
}
.tc-text .hl-c{color:var(--ceo-c);font-weight:500;}
.tc-text .hl-e{color:#6ab0d0;font-weight:500;}
.tc-text .hl-o{color:var(--ceo-o);font-weight:500;}
.tc-text .hl-bad{color:rgba(201,70,46,0.5);text-decoration:underline;text-decoration-style:wavy;text-decoration-color:rgba(201,70,46,0.3);}
.tc-label{
  display:inline-flex;align-items:center;gap:6px;
  font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:2px 8px;margin-left:6px;border-radius:2px;vertical-align:middle;
}
.tc-label.c{background:rgba(201,70,46,0.2);color:var(--ceo-c);}
.tc-label.e{background:rgba(45,110,142,0.2);color:#6ab0d0;}
.tc-label.o{background:rgba(74,140,92,0.2);color:var(--ceo-o);}
.tc-obs{
  margin-top:16px;padding:12px 16px;
  background:rgba(255,255,255,0.04);
  font-size:12px;color:rgba(255,255,255,0.45);line-height:1.6;
}
.tc-side.strong .tc-obs{border-left:2px solid var(--ceo-o);}
.tc-side.weak .tc-obs{border-left:2px solid rgba(201,70,46,0.3);}

/* ─── SLIDE 10: BUILD YOUR OWN CEO ─── */
#s10{background:#f5f0ea;}
.ceo-builder{max-width:760px;width:100%;margin-top:28px;}
.cb-row{
  margin-bottom:20px;
  opacity:0;transform:translateY(12px);
  transition:opacity 0.4s ease,transform 0.4s ease;
}
.cb-row.show{opacity:1;transform:translateY(0);}
.cb-label{
  font-size:11px;font-weight:700;letter-spacing:.15em;
  text-transform:uppercase;margin-bottom:8px;
  display:flex;align-items:center;gap:10px;
}
.cb-letter{
  width:28px;height:28px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'Playfair Display',serif;font-size:14px;font-weight:900;color:white;
}
.cb-letter.c{background:var(--ceo-c);}
.cb-letter.e{background:var(--ceo-e);}
.cb-letter.o{background:var(--ceo-o);}
.cb-input{
  width:100%;padding:14px 18px;
  background:white;border:1px solid #e8e0d4;
  border-left:3px solid transparent;
  font-family:'DM Sans',sans-serif;font-size:15px;
  color:var(--ink);outline:none;
  transition:border-color 0.2s;
  resize:none;
}
.cb-row.c .cb-input{border-left-color:var(--ceo-c);}
.cb-row.e .cb-input{border-left-color:var(--ceo-e);}
.cb-row.o .cb-input{border-left-color:var(--ceo-o);}
.cb-input:focus{border-color:#e8e0d4;border-left-color:inherit;box-shadow:0 0 0 3px rgba(26,16,24,0.04);}
.cb-input::placeholder{color:#b0a8a4;}
.cb-prompt{font-size:12px;color:var(--muted);margin-top:6px;}
.cb-preview{
  margin-top:20px;padding:20px 24px;
  background:white;border-top:3px solid var(--ink);
  display:none;
}
.cb-preview.visible{display:block;}
.cb-preview-label{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.cb-preview-text{font-size:15px;color:var(--ink);line-height:1.8;}
.cb-preview-text .pc{color:var(--ceo-c);font-weight:600;}
.cb-preview-text .pe{color:var(--ceo-e);}
.cb-preview-text .po{color:var(--ceo-o);font-weight:600;}

/* ─── SLIDE 12: COMMUNITY POSTS ─── */
#s12{background:var(--ink);}
.log-card{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);padding:28px;}
.log-header{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:var(--cream);border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:12px;margin-bottom:16px;}
.log-today{padding:14px 16px;background:rgba(255,255,255,0.04);font-size:15px;color:rgba(255,255,255,0.55);font-style:italic;border-left:2px solid var(--accent2);line-height:1.9;}

/* ─── SLIDE 13: TASK ─── */
#s13{background:var(--accent);}
#s13 h2{color:white;}
#s13 .label{color:rgba(255,255,255,0.6);}
.task-box{background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);padding:32px;max-width:700px;margin-top:32px;}
.task-list{list-style:none;margin-top:16px;}
.task-list li{display:flex;align-items:flex-start;gap:14px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.12);font-size:15px;color:white;}
.task-list li:last-child{border:none;}
.task-check{width:26px;height:26px;border-radius:50%;border:2px solid rgba(255,255,255,0.5);flex-shrink:0;margin-top:2px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.task-check.checked{background:white;border-color:white;color:var(--accent);font-size:13px;}
.task-min{margin-top:24px;padding:16px;background:rgba(0,0,0,0.2);font-size:13px;color:rgba(255,255,255,0.8);font-style:italic;}

