<script>
  const totalSlides = 13;
  let current = 0;

  const pillsEl = document.getElementById('pills');
  for (let i = 0; i < totalSlides; i++) {
    const p = document.createElement('div');
    p.className = 'pill' + (i === 0 ? ' active' : '');
    p.onclick = () => goTo(i);
    pillsEl.appendChild(p);
  }

  const streakRow = document.getElementById('streakRow');
  for (let d = 1; d <= 30; d++) {
    const el = document.createElement('div');
    if (d <= 4) el.className = 'streak-day done';
    else if (d === 5) el.className = 'streak-day lit';
    else el.className = 'streak-day';
    el.textContent = d;
    streakRow.appendChild(el);
  }

  function goTo(idx) {
    if (idx < 0 || idx >= totalSlides) return;
    const slides = document.querySelectorAll('.slide');
    slides[current].classList.remove('active');
    current = idx;
    slides[current].classList.add('active');
    updateUI();
    triggerAnimations(idx);
    slides[current].scrollIntoView({ behavior: 'auto' });
  }
  function go(dir) { goTo(current + dir); }

  function updateUI() {
    document.getElementById('prog').style.width = ((current + 1) / totalSlides * 100) + '%';
    document.getElementById('counter').textContent = (current + 1) + ' / ' + totalSlides;
    document.getElementById('nav-prev').style.opacity = current === 0 ? '0.3' : '1';
    document.getElementById('nav-next').style.opacity = current === totalSlides - 1 ? '0.3' : '1';
    pillsEl.querySelectorAll('.pill').forEach((p, i) => {
      p.classList.remove('active', 'done');
      if (i === current) p.classList.add('active');
      else if (i < current) p.classList.add('done');
    });
  }

  let animated = new Set();
  function triggerAnimations(idx) {
    if (animated.has(idx)) return;
    animated.add(idx);

    if (idx === 1) {
      document.querySelectorAll('#journeyTrack .jstep')
        .forEach((s, i) => setTimeout(() => s.classList.add('show'), i * 100));
    }
    if (idx === 2) {
      // Animate rush reasons staggered
      setTimeout(() => {
        document.querySelectorAll('#rushReasons .rush-reason')
          .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 130));
      }, 400);
    }
    if (idx === 3) {
      document.querySelectorAll('#breakTimeline .break-moment')
        .forEach((m, i) => setTimeout(() => m.classList.add('show'), i * 200));
    }
    if (idx === 4) {
      setTimeout(() => document.getElementById('ceoDef').classList.add('show'), 500);
    }
    if (idx === 6) {
      setTimeout(() => {
        document.querySelectorAll('#explainPhrases .ep-row')
          .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 100));
        setTimeout(() => document.getElementById('explainRule').classList.add('show'), 600);
      }, 200);
    }
    if (idx === 7) {
      document.querySelectorAll('#endingTypes .ending-type')
        .forEach((t, i) => setTimeout(() => t.classList.add('show'), i * 150));
    }
    if (idx === 9) {
      document.querySelectorAll('#ceoBuilder .cb-row')
        .forEach((r, i) => setTimeout(() => { r.style.opacity='1'; r.style.transform='translateY(0)'; }, i * 150));
    }
    if (idx === 10) {
      document.querySelectorAll('#scoreGuide .sg-card')
        .forEach((c, i) => setTimeout(() => { c.style.opacity='1'; c.style.transform='translateY(0)'; }, i * 80));
    }
  }

  function updatePreview() {
    const c = document.getElementById('cInput').value.trim();
    const e = document.getElementById('eInput').value.trim();
    const o = document.getElementById('oInput').value.trim();
    const preview = document.getElementById('cbPreview');
    const text = document.getElementById('previewText');
    if (!c && !e && !o) { preview.classList.remove('visible'); return; }
    preview.classList.add('visible');
    let html = '';
    if (c) html += `<span class="pc">${c}</span> `;
    if (e) html += `<span class="pe">${e}</span> `;
    if (o) html += `<span class="po">${o}</span>`;
    text.innerHTML = html;
  }

  // Init builder rows visible
  document.querySelectorAll('#ceoBuilder .cb-row').forEach(r => {
    r.style.opacity = '1'; r.style.transform = 'translateY(0)';
  });

  function checkTask(el) {
    el.classList.toggle('checked');
    el.textContent = el.classList.contains('checked') ? '✓' : '';
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === ' ') go(1);
    if (e.key === 'ArrowLeft') go(-1);
  });

  goTo(0);
</script>
</body>
</html>
