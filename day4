<script>
  const totalSlides = 14;
  let current = 0;

  const pillsEl = document.getElementById('pills');
  for (let i = 0; i < totalSlides; i++) {
    const p = document.createElement('div');
    p.className = 'pill' + (i === 0 ? ' active' : '');
    p.onclick = () => goTo(i);
    pillsEl.appendChild(p);
  }

  const streakRow = document.getElementById('streakRow');
  for (let d = 1; d <= 30; d++) {
    const el = document.createElement('div');
    if (d <= 3) el.className = 'streak-day done';
    else if (d === 4) el.className = 'streak-day lit';
    else el.className = 'streak-day';
    el.textContent = d;
    streakRow.appendChild(el);
  }

  function goTo(idx) {
    if (idx < 0 || idx >= totalSlides) return;
    const slides = document.querySelectorAll('.slide');
    slides[current].classList.remove('active');
    current = idx;
    slides[current].classList.add('active');
    updateUI();
    triggerAnimations(idx);
    slides[current].scrollIntoView({ behavior: 'auto' });
  }
  function go(dir) { goTo(current + dir); }

  function updateUI() {
    document.getElementById('prog').style.width = ((current + 1) / totalSlides * 100) + '%';
    document.getElementById('counter').textContent = (current + 1) + ' / ' + totalSlides;
    document.getElementById('nav-prev').style.opacity = current === 0 ? '0.3' : '1';
    document.getElementById('nav-next').style.opacity = current === totalSlides - 1 ? '0.3' : '1';
    pillsEl.querySelectorAll('.pill').forEach((p, i) => {
      p.classList.remove('active', 'done');
      if (i === current) p.classList.add('active');
      else if (i < current) p.classList.add('done');
    });
  }

  let animated = new Set();
  function triggerAnimations(idx) {
    if (animated.has(idx)) return;
    animated.add(idx);

    if (idx === 1) {
      document.querySelectorAll('#journeyTrack .jstep')
        .forEach((s, i) => setTimeout(() => s.classList.add('show'), i * 100));
    }
    if (idx === 2) {
      setTimeout(() => {
        document.querySelectorAll('#entryCompare .entry-side')
          .forEach(s => s.classList.add('show'));
      }, 300);
    }
    if (idx === 3) {
      setTimeout(() => {
        document.getElementById('ibsDef').classList.add('show');
        setTimeout(() => {
          document.querySelectorAll('#ibsPillars .ibs-pillar')
            .forEach((p, i) => setTimeout(() => p.classList.add('show'), i * 150));
        }, 400);
      }, 200);
    }
    if (idx === 4) {
      document.querySelectorAll('#seqOverview .seq-card')
        .forEach((c, i) => setTimeout(() => c.classList.add('show'), i * 130));
    }
    if (idx === 6) {
      document.querySelectorAll('#roleGrid .role-card')
        .forEach((c, i) => setTimeout(() => {
          c.style.opacity = '1'; c.style.transform = 'translateY(0)';
        }, i * 100));
    }
    if (idx === 7) {
      setTimeout(() => {
        document.querySelectorAll('#groundingSteps .gs-step')
          .forEach((s, i) => setTimeout(() => s.classList.add('show'), i * 150));
      }, 300);
    }
    if (idx === 8) {
      setTimeout(() => {
        document.querySelectorAll('.reset-step')
          .forEach((s, i) => setTimeout(() => {
            s.style.opacity = '1'; s.style.transform = 'translateY(0)';
          }, i * 250));
        setTimeout(() => {
          const n = document.getElementById('resetNote');
          if (n) n.style.opacity = '1';
        }, 900);
      }, 300);
    }
    if (idx === 10) {
      setTimeout(() => {
        document.querySelectorAll('#ritualBox .ritual-row')
          .forEach((r, i) => setTimeout(() => r.classList.add('show'), i * 150));
      }, 300);
    }
  }

  function checkTask(el) {
    el.classList.toggle('checked');
    el.textContent = el.classList.contains('checked') ? '✓' : '';
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === ' ') go(1);
    if (e.key === 'ArrowLeft') go(-1);
  });

  goTo(0);
</script>
